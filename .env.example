# Hugging Face token (required for speaker diarization)
# 1. Create account at https://huggingface.co
# 2. Accept pyannote model terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Create token at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Whisper model size: tiny, base, small, medium, large
# Larger models are more accurate but slower and use more memory
WHISPER_MODEL=base

# Transcription engine: whisper or faster-whisper
# faster-whisper uses CTranslate2 for ~4x faster CPU inference with int8 quantization
WHISPER_ENGINE=whisper

# Output directory for transcripts
OUTPUT_DIR=transcripts

# SQLite database path (GUI mode)
DB_PATH=podcasts.db

# OpenAI API key (required for AI analysis of transcripts)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model for transcript analysis
# Options include gpt-5.1, gpt-5-mini, gpt-5-nano, gpt-40
OPENAI_MODEL=gpt-5.1

# Default prompt template for AI analysis
OPENAI_PROMPT=Summarize this podcast transcript. Provide key topics discussed, main takeaways, and a brief overview.
